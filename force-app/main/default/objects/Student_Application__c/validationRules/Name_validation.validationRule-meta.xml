<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Name_validation</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(REGEX( Student_Name__c , &quot;^[a-zA-Z ]+$&quot;))</errorConditionFormula>
    <errorDisplayField>Student_Name__c</errorDisplayField>
    <errorMessage>Name cannot contain numbers. Please enter only letters.</errorMessage>
</ValidationRule>
